@startuml

rectangle "Modelo de Dominio" {
rectangle Proyecto
rectangle Documentacion
rectangle CasoDeUso
rectangle RequisitoFuncional
rectangle EscenarioPrueba
rectangle CasoPrueba

Proyecto o-- Documentacion 

Documentacion *-- CasoDeUso 
Documentacion *-- RequisitoFuncional 

EscenarioPrueba -- CasoDeUso : valida
EscenarioPrueba -- RequisitoFuncional : valida
EscenarioPrueba --> CasoPrueba : concretar en
}

rectangle "KiwiTCMS\n[sistema externo participante]" as KiwiTCMS
CasoPrueba --> KiwiTCMS: publicar/sincronizar en

@enduml
